<!DOCTYPE html>
<html lang="tr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Buse Deniz & Taner - Nişan Davetiyesi</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;0,900;1,400;1,700&family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400&family=Great+Vibes&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{margin:0;padding:0;box-sizing:border-box}
:root{
  --parchment:#F0E8D8;--parchment-light:#F5F0E5;--parchment-dark:#E4D9C5;
  --gold:#B8935A;--gold-light:#D4BC8B;--gold-dark:#8B6F3A;
  --charcoal:#2C2C2C;--text-dark:#3A332A;--text-soft:#7A6F60;
  --rose:#C47A82;--rose-light:#D4A0A5;--rose-dark:#A85860;
}
html{scroll-behavior:smooth}
body{font-family:'Cormorant Garamond',Georgia,serif;background:#1a1814;color:var(--text-dark);overflow-x:hidden;-webkit-font-smoothing:antialiased}

.wrap{max-width:480px;margin:0 auto;background:var(--parchment);min-height:100vh;position:relative;overflow:hidden;
  background-image:radial-gradient(ellipse at 20% 50%,rgba(212,188,139,0.15) 0%,transparent 50%),radial-gradient(ellipse at 80% 30%,rgba(196,122,130,0.06) 0%,transparent 40%)}

.border{position:fixed;top:0;bottom:0;width:480px;left:50%;transform:translateX(-50%);pointer-events:none;z-index:10}
.border::before{content:'';position:absolute;inset:8px;border:1px solid rgba(184,147,90,0.25)}

/* HERO */
.hero{position:relative;padding:60px 36px 36px;text-align:center;min-height:48vh;display:flex;flex-direction:column;align-items:center;justify-content:center}
.hero-label{font-size:12px;font-weight:600;letter-spacing:7px;text-transform:uppercase;color:var(--gold);margin-bottom:28px;opacity:0;animation:fadeUp .8s ease .3s forwards}
.names{margin-bottom:14px;opacity:0;animation:fadeUp .8s ease .5s forwards}
.names h1{font-family:'Playfair Display',serif;font-size:50px;font-weight:700;font-style:italic;color:var(--charcoal);line-height:1.05}
.names .amp{font-family:'Great Vibes',cursive;font-size:54px;color:var(--rose);display:block;margin:2px 0;line-height:1.2}
.hearts{display:flex;gap:6px;justify-content:center;margin:14px 0 22px;opacity:0;animation:fadeIn .8s ease .8s forwards}
.hearts span{color:var(--rose-light);font-size:10px}
.hearts span:nth-child(2){color:var(--rose);font-size:13px;animation:pulse 2.5s ease-in-out infinite}
.gline{width:100px;height:1px;background:linear-gradient(90deg,transparent,var(--gold),transparent);margin:0 auto;opacity:0;animation:fadeIn .8s ease .9s forwards}
.hero-msg{margin-top:22px;font-size:17px;font-weight:300;font-style:italic;color:var(--text-soft);line-height:1.9;opacity:0;animation:fadeUp .8s ease 1s forwards}

/* IMAGE */
.img-sec{padding:0;text-align:center}
.img-wrap{position:relative;margin:0 24px;border-radius:3px;overflow:hidden;box-shadow:0 2px 20px rgba(60,45,20,0.12),0 0 0 1px rgba(184,147,90,0.15)}
.img-wrap img{width:100%;display:block}
.img-wrap::before{content:'';position:absolute;inset:0;box-shadow:inset 0 -20px 30px -10px var(--parchment),inset 0 20px 30px -10px var(--parchment);z-index:2;pointer-events:none}
.img-wrap::after{content:'';position:absolute;inset:0;box-shadow:inset 20px 0 30px -15px var(--parchment),inset -20px 0 30px -15px var(--parchment);z-index:2;pointer-events:none}

/* SCROLL */
.scroll-cta{text-align:center;padding:28px 0 8px;opacity:0;animation:fadeIn 1s ease 1.6s forwards;cursor:pointer}
.scroll-cta span{font-size:10px;letter-spacing:4px;text-transform:uppercase;color:var(--gold);display:block;margin-bottom:8px}
.chevron{display:inline-block;width:14px;height:14px;border-right:1px solid var(--gold);border-bottom:1px solid var(--gold);transform:rotate(45deg);animation:bounce 1.8s ease infinite}

/* DETAILS */
.details{padding:46px 30px}
.slabel{font-size:11px;font-weight:600;letter-spacing:5px;text-transform:uppercase;color:var(--gold);text-align:center;margin-bottom:34px}
.card{text-align:center;margin-bottom:32px;padding:26px 18px;background:rgba(245,240,229,0.6);border:1px solid rgba(184,147,90,0.12);border-radius:8px;position:relative}
.card::after{content:'';position:absolute;top:0;left:20%;right:20%;height:2px;background:linear-gradient(90deg,transparent,var(--gold-light),var(--rose-light),var(--gold-light),transparent)}
.card-icon{font-size:22px;margin-bottom:10px;display:block}
.card-lbl{font-size:10px;font-weight:600;letter-spacing:3px;text-transform:uppercase;color:var(--gold);margin-bottom:10px}
.card-val{font-family:'Playfair Display',serif;font-size:21px;font-weight:700;color:var(--charcoal);line-height:1.4}
.card-sub{font-size:15px;color:var(--text-soft);font-style:italic;margin-top:4px}
.map-btn{display:inline-flex;align-items:center;gap:6px;margin-top:14px;padding:9px 22px;background:var(--gold);color:white;text-decoration:none;border-radius:24px;font-size:12px;font-weight:600;letter-spacing:1.5px;text-transform:uppercase}

/* COUNTDOWN */
.cd-sec{padding:40px 30px 46px;text-align:center;background:linear-gradient(180deg,transparent,rgba(228,217,197,0.4))}
.cd-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:10px;max-width:340px;margin:26px auto 0}
.cd-item{padding:14px 6px;background:rgba(245,240,229,0.7);border:1px solid rgba(184,147,90,0.12);border-radius:8px}
.cd-num{font-family:'Playfair Display',serif;font-size:32px;font-weight:900;color:var(--charcoal);line-height:1}
.cd-lbl{font-size:9px;letter-spacing:2px;text-transform:uppercase;color:var(--gold);margin-top:5px;font-weight:600}

/* RSVP */
.rsvp{padding:44px 30px 36px;text-align:center}
.rsvp-text{font-size:16px;font-style:italic;color:var(--text-soft);line-height:1.8;margin-bottom:22px}
.cal-btn{display:inline-flex;align-items:center;gap:8px;padding:13px 30px;background:var(--rose);color:white;border:none;border-radius:24px;font-family:'Cormorant Garamond',serif;font-size:15px;font-weight:600;letter-spacing:1px;text-decoration:none}

/* FOOTER */
.footer{padding:28px 30px 50px;text-align:center}
.footer-msg{font-size:15px;color:var(--text-soft);font-style:italic;margin-bottom:5px}
.footer-fam{font-family:'Playfair Display',serif;font-size:19px;font-weight:700;color:var(--charcoal)}

@keyframes fadeUp{from{opacity:0;transform:translateY(18px)}to{opacity:1;transform:translateY(0)}}
@keyframes fadeIn{from{opacity:0}to{opacity:1}}
@keyframes pulse{0%,100%{transform:scale(1)}50%{transform:scale(1.3)}}
@keyframes bounce{0%,100%{transform:rotate(45deg) translateY(0)}50%{transform:rotate(45deg) translateY(5px)}}

@media(max-width:480px){
  .names h1{font-size:42px}
  .names .amp{font-size:44px}
  .img-wrap{margin:0 18px}
  .cd-num{font-size:26px}
  .border{width:100%}
}
</style>
</head>
<body>
<div class="wrap">
<div class="border"></div>

<section class="hero">
  <div class="hero-label">Nişan Davetiyesi</div>
  <div class="names">
    <h1>Buse Deniz</h1>
    <span class="amp">&</span>
    <h1>Taner</h1>
  </div>
  <div class="hearts"><span>◆</span><span>♥</span><span>◆</span></div>
  <div class="gline"></div>
  <p class="hero-msg">Özel davetimizde sizleri de görmekten<br>mutluluk duyarız.</p>
</section>

<section class="img-sec">
  <div class="img-wrap">
    <img src="data:image/jpeg;base64," alt="Buse Deniz ve Taner">
  </div>
</section>

<div class="scroll-cta" onclick="document.getElementById('det').scrollIntoView({behavior:'smooth'})">
  <span>Detaylar</span>
  <div class="chevron"></div>
</div>

<section class="details" id="det">
  <div class="slabel">Davet Detayları</div>
  <div class="card">
    <span class="card-icon">📅</span>
    <div class="card-lbl">Tarih & Saat</div>
    <div class="card-val">9 Mayıs 2026, Cumartesi</div>
    <div class="card-sub">Saat 19.30</div>
  </div>
  <div class="card">
    <span class="card-icon">📍</span>
    <div class="card-lbl">Mekân</div>
    <div class="card-val">Appos — Event & Breakfast<br>& Social Club</div>
    <div class="card-sub">Tülbentli, Eski Foça Yolu Sk. 1 Km No:112<br>Menemen / İzmir</div>
    <a href="https://maps.google.com/?q=Appos+Event+Breakfast+Social+Club+Menemen+İzmir" target="_blank" rel="noopener" class="map-btn">📍 Haritada Göster</a>
  </div>
</section>

<section class="cd-sec">
  <div class="slabel">Nişana Kalan Süre</div>
  <div class="cd-grid">
    <div class="cd-item"><div class="cd-num" id="d">--</div><div class="cd-lbl">Gün</div></div>
    <div class="cd-item"><div class="cd-num" id="h">--</div><div class="cd-lbl">Saat</div></div>
    <div class="cd-item"><div class="cd-num" id="m">--</div><div class="cd-lbl">Dakika</div></div>
    <div class="cd-item"><div class="cd-num" id="s">--</div><div class="cd-lbl">Saniye</div></div>
  </div>
</section>

<section class="rsvp">
  <div class="gline" style="margin-bottom:26px"></div>
  <p class="rsvp-text">Katılım durumunuzu bildirmenizi<br>rica ederiz.</p>
  <a href="https://calendar.google.com/calendar/render?action=TEMPLATE&text=Buse+Deniz+%26+Taner+Ni%C5%9Fan+T%C3%B6reni&dates=20260509T163000Z/20260509T203000Z&details=Ni%C5%9Fan+T%C3%B6reni&location=Appos+Event+Breakfast+Social+Club+Menemen+%C4%B0zmir" target="_blank" rel="noopener" class="cal-btn">📅 Takvime Ekle</a>
</section>

<section class="footer">
  <div class="gline" style="margin-bottom:22px"></div>
  <p class="footer-msg">Sevgi ve saygılarımızla,</p>
  <p class="footer-fam">Şen & Tosun Ailesi</p>
</section>

</div>

<script>
(function(){
  var hedef = new Date(2026,4,9,19,30,0);
  var de = document.getElementById("d");
  var he = document.getElementById("h");
  var me = document.getElementById("m");
  var se = document.getElementById("s");
  function say(){
    var f = hedef.getTime() - Date.now();
    if(f<0){de.innerHTML="0";he.innerHTML="0";me.innerHTML="0";se.innerHTML="0";return}
    de.innerHTML = Math.floor(f/86400000);
    he.innerHTML = Math.floor((f%86400000)/3600000);
    me.innerHTML = Math.floor((f%3600000)/60000);
    se.innerHTML = Math.floor((f%60000)/1000);
  }
  say();
  setInterval(say,1000);
})();
</script>
</body>
</html>
